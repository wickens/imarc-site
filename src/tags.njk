---
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: "tag/{{ tag }}/index.html"
layout: base.njk
---
<h1>Tag: {{ tag }}</h1>
<ul class="archive-list">
{% for post in collections.posts | withTag(tag) %}
  <li><time datetime="{{ post.date | isoDate }}">{{ post.date | date }}</time> — <a href="{{ post.url }}">{{ post.data.title }}</a></li>
{% endfor %}
</ul>
